#!/usr/bin/env bash
set -euo pipefail

product_name="$(cat /sys/class/dmi/id/product_version 2>/dev/null || true)"
rotation="${1:-0}"
rotate_path="/sys/class/graphics/fbcon/rotate_all"
keymap="/usr/share/keymaps/i386/colemak/en-latin9.map.gz"

dhcp_if=""
static_if=""
static_addrs=()
modules=()
reverse_tunnel_services=(
  sshd
  reverse-ssh-eu
  reverse-ssh-us
)

case "$product_name" in
  *"ThinkPad E14"*)
    modules=(
      mt7921e
    )
    ;;
  *)
    dhcp_if="eno1"
    static_if="enp65s0"
    static_addrs=(
      "192.168.254.123/24"
      "192.168.178.122/24"
    )
    modules=(
      r8169
      igc
    )
    ;;
esac

try_modprobe() {
  local module="$1"
  sudo modprobe "$module" 2>/dev/null || true
}

have_link() {
  local link="$1"
  [ -n "$link" ] && [ -e "/sys/class/net/$link" ]
}

sudo -v

echo "Loading Colemak console keymap"
sudo loadkeys "$keymap"

if [ -w "$rotate_path" ]; then
  case "$rotation" in
    0|1|2|3)
      :
      ;;
    *)
      echo "Usage: $0 [0|1|2|3]" >&2
      exit 1
      ;;
  esac
fi

if [ "${#modules[@]}" -gt 0 ]; then
  echo "Loading network modules"
  for module in "${modules[@]}"; do
    try_modprobe "$module"
  done
fi

if have_link "$dhcp_if"; then
  echo "Refreshing DHCP on ${dhcp_if}"
  sudo ip link set dev "$dhcp_if" up
  if command -v pkill >/dev/null 2>&1; then
    sudo pkill -f "dhclient.*${dhcp_if}" || true
  fi
  sudo dhclient -r "$dhcp_if" || true
  sudo dhclient -v "$dhcp_if"
  ip -br addr show dev "$dhcp_if"
fi

if have_link "$static_if"; then
  echo "Applying static addresses on ${static_if}"
  sudo ip link set dev "$static_if" up
  sudo ip -4 addr flush dev "$static_if" scope global || true
  for addr in "${static_addrs[@]}"; do
    sudo ip addr add "$addr" dev "$static_if"
  done
  ip -br addr show dev "$static_if"
fi

for svc in "${reverse_tunnel_services[@]}"; do
  if [ -x "/etc/init.d/${svc}" ]; then
    echo "Ensuring ${svc} is running"
    sudo rc-service "$svc" restart || sudo rc-service "$svc" start
  fi
done
