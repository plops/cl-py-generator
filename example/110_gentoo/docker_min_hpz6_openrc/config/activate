#!/bin/sh
set -eu

try_modprobe() {
  modprobe "$1" 2>/dev/null || true
}

rc-service udev start
rc-service udev-trigger start
rc-service udev-settle start
rc-service hostname start
rc-service dbus start

KEYMAP_PATH="$(find /usr/share/keymaps -path '*/colemak/en.latin*.gz' | sort | head -n 1)"
if [ -n "${KEYMAP_PATH}" ]; then
  loadkeys "${KEYMAP_PATH}"
fi

# Refresh dynamic linker state after GCC slot changes so interactive
# applications can find libgcc_s/libstdc++ again.
env-update
ldconfig

depmod -a
modprobe amdgpu
modprobe mt7921e
try_modprobe snd_hda_intel
try_modprobe snd_pci_ps
try_modprobe snd_soc_ps_mach
try_modprobe snd_sof_amd_acp63
